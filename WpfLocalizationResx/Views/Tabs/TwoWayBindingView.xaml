<UserControl x:Class="WpfLocalizationResx.Views.Tabs.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfLocalizationResx.ViewModels">

    <UserControl.DataContext>
        <vm:TwoWayBindingViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Localization.TwoWayTitle}"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,20"
                       Text="{Binding Localization.TwoWayDescription}"/>

            <TextBlock Text="{Binding Localization.ElementBindingTwoWay}"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.TextBox1}" VerticalAlignment="Center" Width="120"/>
                <TextBox x:Name="SourceTextBox" Width="200" Padding="4"
                         Text="{Binding Localization.SyncText, Mode=OneWay}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.TextBox2}" VerticalAlignment="Center" Width="120"/>
                <TextBox Width="200" Padding="4"
                         Text="{Binding ElementName=SourceTextBox, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="{Binding Localization.Slider}" VerticalAlignment="Center" Width="120"/>
                <Slider x:Name="DirectSlider" Width="150" Minimum="0" Maximum="100" Value="50"/>
                <TextBox Width="60" Margin="10,0,0,0" Padding="4"
                         Text="{Binding ElementName=DirectSlider, Path=Value, Mode=TwoWay, StringFormat={}{0:F0}}"/>
            </StackPanel>

            <Separator Margin="0,0,0,20"/>

            <TextBlock Text="{Binding Localization.ViewModelBindingTwoWay}"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.TextBox1}" VerticalAlignment="Center" Width="120"/>
                <TextBox Width="200" Padding="4"
                         Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.Display}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding TextValue}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.Slider}" VerticalAlignment="Center" Width="120"/>
                <Slider Value="{Binding SliderValue, Mode=TwoWay}"
                        Width="150" Minimum="0" Maximum="100"/>
                <TextBox Width="60" Margin="10,0,0,0" Padding="4"
                         Text="{Binding SliderValue, Mode=TwoWay, StringFormat={}{0:F0}}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.Progress}" VerticalAlignment="Center" Width="120"/>
                <ProgressBar Value="{Binding SliderValue, Mode=TwoWay}"
                             Width="200" Height="20" Minimum="0" Maximum="100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.CheckBox}" VerticalAlignment="Center" Width="120"/>
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Content="{Binding Localization.Enable}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.State}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding IsChecked}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{Binding Localization.ComboBox}" VerticalAlignment="Center" Width="120"/>
                <ComboBox SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}" Width="200">
                    <ComboBoxItem Content="{Binding Localization.OptionA}"/>
                    <ComboBoxItem Content="{Binding Localization.OptionB}"/>
                    <ComboBoxItem Content="{Binding Localization.OptionC}"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="{Binding Localization.SelectedIndex}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding SelectedIndex}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <Button Content="{Binding Localization.ResetAll}"
                    Command="{Binding ResetCommand}"
                    HorizontalAlignment="Left" Padding="12,6"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
