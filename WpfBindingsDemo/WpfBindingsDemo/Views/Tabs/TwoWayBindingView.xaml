<UserControl x:Class="WpfBindingsDemo.Views.Tabs.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfBindingsDemo.ViewModels">

    <UserControl.DataContext>
        <vm:TwoWayBindingViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Заголовок -->
            <TextBlock Text="Двухсторонняя привязка (TwoWay)"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,20"
                       Text="TwoWay — изменения идут в обе стороны: из UI в ViewModel и из ViewModel в UI. Любое изменение в одном месте сразу отражается в другом."/>

            <!-- Прямая привязка между элементами -->
            <TextBlock Text="1. Прямая привязка между элементами (TwoWay)"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="TextBox 1: " VerticalAlignment="Center" Width="120"/>
                <TextBox x:Name="SourceTextBox" Width="200" Padding="4"
                         Text="Синхронный текст"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="TextBox 2: " VerticalAlignment="Center" Width="120"/>
                <TextBox Width="200" Padding="4"
                         Text="{Binding ElementName=SourceTextBox, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Слайдер: " VerticalAlignment="Center" Width="120"/>
                <Slider x:Name="DirectSlider" Width="150" Minimum="0" Maximum="100" Value="50"/>
                <TextBox Width="60" Margin="10,0,0,0" Padding="4"
                         Text="{Binding ElementName=DirectSlider, Path=Value, Mode=TwoWay, StringFormat={}{0:F0}}"/>
            </StackPanel>

            <Separator Margin="0,0,0,20"/>

            <!-- Привязка через ViewModel -->
            <TextBlock Text="2. Привязка через ViewModel (TwoWay)"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="TextBox: " VerticalAlignment="Center" Width="120"/>
                <TextBox Width="200" Padding="4"
                         Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Отображение: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding TextValue}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Слайдер: " VerticalAlignment="Center" Width="120"/>
                <Slider Value="{Binding SliderValue, Mode=TwoWay}"
                        Width="150" Minimum="0" Maximum="100"/>
                <TextBox Width="60" Margin="10,0,0,0" Padding="4"
                         Text="{Binding SliderValue, Mode=TwoWay, StringFormat={}{0:F0}}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Прогресс: " VerticalAlignment="Center" Width="120"/>
                <ProgressBar Value="{Binding SliderValue, Mode=TwoWay}"
                             Width="200" Height="20" Minimum="0" Maximum="100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="CheckBox: " VerticalAlignment="Center" Width="120"/>
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Content="Включить" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Состояние: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding IsChecked}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="ComboBox: " VerticalAlignment="Center" Width="120"/>
                <ComboBox SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}" Width="200">
                    <ComboBoxItem Content="Вариант А"/>
                    <ComboBoxItem Content="Вариант Б"/>
                    <ComboBoxItem Content="Вариант В"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Выбран индекс: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding SelectedIndex}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <!-- Кнопка сброса -->
            <Button Content="Сбросить все значения"
                    Command="{Binding ResetCommand}"
                    HorizontalAlignment="Left" Padding="12,6"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>