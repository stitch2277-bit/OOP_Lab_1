<UserControl x:Class="WpfBindingsDemo.Views.Tabs.OneWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfBindingsDemo.ViewModels">

    <UserControl.DataContext>
        <vm:OneWayBindingViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Заголовок -->
            <TextBlock Text="Односторонние привязки (OneWay / OneWayToSource)"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,20"
                       Text="OneWay — данные идут только из ViewModel в UI. OneWayToSource — данные идут только из UI в ViewModel. Изменения в противоположном направлении игнорируются."/>

            <!-- OneWay -->
            <TextBlock Text="1. OneWay — из ViewModel в UI"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"
                       Text="UI отображает данные из VM. Изменить значение в UI нельзя — оно всегда диктуется ViewModel."/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Текст (OneWay):" VerticalAlignment="Center" Width="180"/>
                <TextBlock Text="{Binding SourceText, Mode=OneWay}"
                           VerticalAlignment="Center" FontWeight="Bold" Foreground="Green"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="TextBox (OneWay):" VerticalAlignment="Center" Width="180"/>
                <TextBox Text="{Binding SourceText, Mode=OneWay}"
                         Width="200" Padding="4" IsReadOnly="True" Background="#F0F0F0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Прогресс (OneWay):" VerticalAlignment="Center" Width="180"/>
                <ProgressBar Value="{Binding SliderValue, Mode=OneWay}"
                             Width="200" Height="20" Minimum="0" Maximum="100"/>
                <TextBlock Text="{Binding SliderValue, Mode=OneWay, StringFormat={}{0:F0}}"
                           Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <Button Content="Обновить данные в ViewModel"
                    Command="{Binding UpdateSourceCommand}"
                    HorizontalAlignment="Left" Padding="12,6" Margin="0,10,0,6"/>

            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,20"
                       Text="Только кнопка может обновить данные — через VM. UI сам по себе не меняет источник."/>

            <Separator Margin="0,0,0,20"/>

            <!-- OneWayToSource -->
            <TextBlock Text="2. OneWayToSource — из UI в ViewModel"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"
                       Text="UI отправляет данные в VM, но VM не может обновить UI через эту привязку."/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Введи текст:" VerticalAlignment="Center" Width="180"/>
                <TextBox Width="200" Padding="4"
                         Text="{Binding InputText, Mode=OneWayToSource,
                                UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="В ViewModel пришло:" VerticalAlignment="Center" Width="180"/>
                <TextBlock Text="{Binding InputText}"
                           VerticalAlignment="Center" FontWeight="Bold" Foreground="OrangeRed"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,10,0,10"
                       Text="Текст из TextBox попадает в VM. Но если VM изменит InputText — TextBox не обновится."/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Слайдер (OneWayToSource):" VerticalAlignment="Center" Width="180"/>
                <Slider Value="{Binding UserSliderValue, Mode=OneWayToSource}"
                        Width="200" Minimum="0" Maximum="100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="В ViewModel пришло:" VerticalAlignment="Center" Width="180"/>
                <TextBlock Text="{Binding UserSliderValue, StringFormat={}{0:F0}}"
                           VerticalAlignment="Center" FontWeight="Bold" Foreground="OrangeRed"/>
            </StackPanel>

            <Button Content="Изменить UserSliderValue в VM (слайдер не обновится)"
                    Command="{Binding RandomSliderCommand}"
                    HorizontalAlignment="Left" Padding="12,6" Margin="0,10,0,6"/>

            <TextBlock TextWrapping="Wrap" Foreground="Gray"
                       Text="Кнопка меняет значение в VM, но слайдер не реагирует — OneWayToSource не передаёт данные из VM в UI."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>