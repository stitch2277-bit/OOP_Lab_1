<UserControl x:Class="WpfBindingsDemo.Views.Tabs.DefaultBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfBindingsDemo.ViewModels">

    <UserControl.DataContext>
        <vm:DefaultBindingViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" >

            <!-- Заголовок -->
            <TextBlock Text="Привязка по умолчанию (Default)"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,20"
                       Text="Default — это поведение привязки по умолчанию для каждого элемента. Для большинства свойств это OneWay, но для редактируемых элементов (TextBox, CheckBox) — TwoWay."/>

            <!-- Разделитель -->
            <TextBlock Text="1. Прямая привязка между элементами (ElementName)"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Введи текст: " VerticalAlignment="Center" Width="120"/>
                <TextBox x:Name="DirectTextBox" Width="200" Padding="4"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Результат: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding ElementName=DirectTextBox, Path=Text}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Слайдер: " VerticalAlignment="Center" Width="120"/>
                <Slider x:Name="DirectSlider" Width="200" Minimum="0" Maximum="100" Value="50"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Значение: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding ElementName=DirectSlider, Path=Value, StringFormat={}{0:F0}}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <!-- Разделитель -->
            <Separator Margin="0,0,0,20"/>

            <TextBlock Text="2. Привязка через ViewModel"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="TextBox: " VerticalAlignment="Center" Width="120"/>
                <TextBox Text="{Binding TextValue}" Width="200" Padding="4"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Результат: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding TextValue}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="CheckBox: " VerticalAlignment="Center" Width="120"/>
                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Состояние: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding IsChecked}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Слайдер VM: " VerticalAlignment="Center" Width="120"/>
                <Slider Value="{Binding SliderValue}" Width="200" Minimum="0" Maximum="100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Значение: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding SliderValue, StringFormat={}{0:F0}}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="ComboBox: " VerticalAlignment="Center" Width="120"/>
                <ComboBox SelectedIndex="{Binding SelectedIndex}" Width="200">
                    <ComboBoxItem Content="Элемент 1"/>
                    <ComboBoxItem Content="Элемент 2"/>
                    <ComboBoxItem Content="Элемент 3"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Выбран индекс: " VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding SelectedIndex}"
                           VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>