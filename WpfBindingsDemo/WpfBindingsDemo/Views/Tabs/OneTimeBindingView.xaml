<UserControl x:Class="WpfBindingsDemo.Views.Tabs.OneTimeBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfBindingsDemo.ViewModels">

    <UserControl.DataContext>
        <vm:OneTimeBindingViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- Заголовок -->
            <TextBlock Text="Одноразовая привязка (OneTime)"
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap" Margin="0,0,0,20"
                       Text="OneTime — значение считывается из источника только один раз при инициализации. Последующие изменения в ViewModel не обновляют UI. Используется для статичных данных."/>

            <!-- Демонстрация OneTime vs OneWay -->
            <TextBlock Text="1. Сравнение OneTime и OneWay"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="OneTime:" VerticalAlignment="Center" Width="160"/>
                <TextBlock Text="{Binding TextValue, Mode=OneTime}"
                           VerticalAlignment="Center" FontWeight="Bold"
                           Foreground="OrangeRed"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="OneWay (для сравнения):" VerticalAlignment="Center" Width="160"/>
                <TextBlock Text="{Binding TextValue, Mode=OneWay}"
                           VerticalAlignment="Center" FontWeight="Bold"
                           Foreground="Green"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Значение в VM:" VerticalAlignment="Center" Width="160"/>
                <TextBlock Text="{Binding TextValue}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Button Content="Обновить значение в ViewModel"
                    Command="{Binding UpdateValuesCommand}"
                    HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,6"/>

            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,20"
                       Text="После нажатия: OneTime НЕ обновится, OneWay — обновится."/>

            <Separator Margin="0,0,0,20"/>

            <!-- Слайдер -->
            <TextBlock Text="2. Слайдер — OneTime vs OneWay"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="OneTime:" VerticalAlignment="Center" Width="160"/>
                <ProgressBar Value="{Binding SliderValue, Mode=OneTime}"
                             Width="200" Height="20" Minimum="0" Maximum="100"/>
                <TextBlock Text="{Binding SliderValue, Mode=OneTime}"
                           Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold"
                           Foreground="OrangeRed"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="OneWay (для сравнения):" VerticalAlignment="Center" Width="160"/>
                <ProgressBar Value="{Binding SliderValue, Mode=OneWay}"
                             Width="200" Height="20" Minimum="0" Maximum="100"/>
                <TextBlock Text="{Binding SliderValue, Mode=OneWay}"
                           Margin="10,0,0,0" VerticalAlignment="Center" FontWeight="Bold"
                           Foreground="Green"/>
            </StackPanel>

            <Button Content="Обновить значения в ViewModel"
                    Command="{Binding UpdateValuesCommand}"
                    HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,6"/>

            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,20"
                       Text="После нажатия: OneTime НЕ изменится, OneWay — изменится."/>

            <Separator Margin="0,0,0,20"/>

            <!-- Время -->
            <TextBlock Text="3. Текущее время — OneTime"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="Зафиксировано (OneTime):" VerticalAlignment="Center" Width="200"/>
                <TextBlock Text="{Binding CurrentTime, Mode=OneTime}"
                           VerticalAlignment="Center" FontWeight="Bold"
                           Foreground="OrangeRed" FontSize="16"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="Актуальное (OneWay):" VerticalAlignment="Center" Width="200"/>
                <TextBlock Text="{Binding CurrentTime, Mode=OneWay}"
                           VerticalAlignment="Center" FontWeight="Bold"
                           Foreground="Green" FontSize="16"/>
            </StackPanel>

            <Button Content="Обновить время в ViewModel"
                    Command="{Binding UpdateTimeCommand}"
                    HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,6"/>

            <TextBlock TextWrapping="Wrap" Foreground="Gray"
                       Text="OneTime показывает время загрузки вкладки. OneWay обновляется при нажатии кнопки."/>

        </StackPanel>
    </ScrollViewer>
</UserControl>