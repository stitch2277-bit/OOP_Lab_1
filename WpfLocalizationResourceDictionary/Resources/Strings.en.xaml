<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- MainWindow -->
    <sys:String x:Key="WindowTitle">WPF Bindings Demo</sys:String>
    <sys:String x:Key="TabDefault">Default Binding</sys:String>
    <sys:String x:Key="TabTwoWay">Two-Way Binding</sys:String>
    <sys:String x:Key="TabOneTime">One-Time Binding</sys:String>
    <sys:String x:Key="TabOneWay">One-Way Binding</sys:String>
    <sys:String x:Key="TabTriggers">Triggers</sys:String>

    <!-- Language Selector -->
    <sys:String x:Key="LanguageSelector">Language:</sys:String>
    <sys:String x:Key="LanguageEnglish">English</sys:String>
    <sys:String x:Key="LanguageRussian">Russian</sys:String>

    <!-- DefaultBindingView -->
    <sys:String x:Key="DefaultBindingTitle">Default Binding (Default)</sys:String>
    <sys:String x:Key="DefaultBindingDescription">Default is the default binding behavior for each element. For most properties it is OneWay, but for editable elements (TextBox, CheckBox) — TwoWay.</sys:String>
    <sys:String x:Key="ElementBinding">1. Direct binding between elements (ElementName)</sys:String>
    <sys:String x:Key="EnterText">Enter text:</sys:String>
    <sys:String x:Key="Result">Result:</sys:String>
    <sys:String x:Key="Slider">Slider:</sys:String>
    <sys:String x:Key="Value">Value:</sys:String>
    <sys:String x:Key="ViewModelBinding">2. ViewModel Binding</sys:String>
    <sys:String x:Key="CheckBox">CheckBox:</sys:String>
    <sys:String x:Key="State">State:</sys:String>
    <sys:String x:Key="SliderVM">Slider VM:</sys:String>
    <sys:String x:Key="ComboBox">ComboBox:</sys:String>
    <sys:String x:Key="SelectedIndex">Selected index:</sys:String>

    <!-- TwoWayBindingView -->
    <sys:String x:Key="TwoWayTitle">Two-Way Binding (TwoWay)</sys:String>
    <sys:String x:Key="TwoWayDescription">TwoWay — changes flow in both directions: from UI to ViewModel and from ViewModel to UI. Any change in one place is immediately reflected in the other.</sys:String>
    <sys:String x:Key="ElementBindingTwoWay">1. Direct binding between elements (TwoWay)</sys:String>
    <sys:String x:Key="TextBox1">TextBox 1:</sys:String>
    <sys:String x:Key="TextBox2">TextBox 2:</sys:String>
    <sys:String x:Key="SyncText">Synchronized text</sys:String>
    <sys:String x:Key="ViewModelBindingTwoWay">2. ViewModel Binding (TwoWay)</sys:String>
    <sys:String x:Key="Display">Display:</sys:String>
    <sys:String x:Key="Progress">Progress:</sys:String>
    <sys:String x:Key="Enable">Enable</sys:String>
    <sys:String x:Key="OptionA">Option A</sys:String>
    <sys:String x:Key="OptionB">Option B</sys:String>
    <sys:String x:Key="OptionC">Option C</sys:String>
    <sys:String x:Key="ResetAll">Reset all values</sys:String>

    <!-- OneTimeBindingView -->
    <sys:String x:Key="OneTimeTitle">One-Time Binding (OneTime)</sys:String>
    <sys:String x:Key="OneTimeDescription">OneTime — the value is read from the source only once during initialization. Subsequent changes in ViewModel do not update UI. Used for static data.</sys:String>
    <sys:String x:Key="CompareOneTime">1. OneTime vs OneWay Comparison</sys:String>
    <sys:String x:Key="ForComparison">(for comparison):</sys:String>
    <sys:String x:Key="ValueInVM">Value in VM:</sys:String>
    <sys:String x:Key="UpdateVMValues">Update ViewModel values</sys:String>
    <sys:String x:Key="OneTimeNotUpdated">After clicking: OneTime will NOT update, OneWay — will update.</sys:String>
    <sys:String x:Key="SliderComparison">2. Slider — OneTime vs OneWay</sys:String>
    <sys:String x:Key="UpdateVMValues2">Update ViewModel values</sys:String>
    <sys:String x:Key="OneTimeNotChanged">After clicking: OneTime will NOT change, OneWay — will change.</sys:String>
    <sys:String x:Key="CurrentTimeOneTime">3. Current time — OneTime</sys:String>
    <sys:String x:Key="FixedOneTime">Fixed (OneTime):</sys:String>
    <sys:String x:Key="ActualOneWay">Actual (OneWay):</sys:String>
    <sys:String x:Key="UpdateTimeVM">Update time in ViewModel</sys:String>
    <sys:String x:Key="OneTimeDesc">OneTime shows the tab load time. OneWay updates when the button is clicked.</sys:String>

    <!-- OneWayBindingView -->
    <sys:String x:Key="OneWayTitle">One-Way Bindings (OneWay / OneWayToSource)</sys:String>
    <sys:String x:Key="OneWayDescription">OneWay — data flows only from ViewModel to UI. OneWayToSource — data flows only from UI to ViewModel. Changes in the opposite direction are ignored.</sys:String>
    <sys:String x:Key="OneWayFromVM">1. OneWay — from ViewModel to UI</sys:String>
    <sys:String x:Key="OneWayDesc1">UI displays data from VM. You cannot change the value in UI — it is always dictated by ViewModel.</sys:String>
    <sys:String x:Key="TextOneWay">Text (OneWay):</sys:String>
    <sys:String x:Key="TextBoxOneWay">TextBox (OneWay):</sys:String>
    <sys:String x:Key="ProgressOneWay">Progress (OneWay):</sys:String>
    <sys:String x:Key="UpdateSourceData">Update ViewModel data</sys:String>
    <sys:String x:Key="OneWayDesc2">Only the button can update data — via VM. UI itself does not change the source.</sys:String>
    <sys:String x:Key="OneWayToSource">2. OneWayToSource — from UI to ViewModel</sys:String>
    <sys:String x:Key="OneWayToSourceDesc">UI sends data to VM, but VM cannot update UI through this binding.</sys:String>
    <sys:String x:Key="EnterText2">Enter text:</sys:String>
    <sys:String x:Key="ReceivedInVM">Received in ViewModel:</sys:String>
    <sys:String x:Key="OneWayToSourceDesc2">Text from TextBox goes to VM. But if VM changes InputText — TextBox will not update.</sys:String>
    <sys:String x:Key="SliderOneWayToSource">Slider (OneWayToSource):</sys:String>
    <sys:String x:Key="ChangeSliderInVM">Change UserSliderValue in VM (slider won't update)</sys:String>
    <sys:String x:Key="OneWayToSourceDesc3">The button changes the value in VM, but the slider does not respond — OneWayToSource does not pass data from VM to UI.</sys:String>

    <!-- TriggersView -->
    <sys:String x:Key="TriggersTitle">Triggers</sys:String>
    <sys:String x:Key="TriggersDescription">Triggers allow changing the appearance of elements based on conditions — without code-behind.</sys:String>
    <sys:String x:Key="Trigger1">1. Trigger — fires on element property</sys:String>
    <sys:String x:Key="Trigger1Desc">Changes the button style when IsEnabled = false. Defined directly in the element's style.</sys:String>
    <sys:String x:Key="EnableButton">Enable button:</sys:String>
    <sys:String x:Key="TriggerButtonText">I change color by Trigger</sys:String>
    <sys:String x:Key="Trigger2">2. DataTrigger — fires on ViewModel data</sys:String>
    <sys:String x:Key="Trigger2Desc">Changes appearance depending on the property value in ViewModel.</sys:String>
    <sys:String x:Key="Ok">OK</sys:String>
    <sys:String x:Key="Error">Error</sys:String>
    <sys:String x:Key="Reset">Reset</sys:String>
    <sys:String x:Key="Trigger3">3. MultiDataTrigger — multiple conditions from ViewModel</sys:String>
    <sys:String x:Key="Trigger3Desc">Fires only when ALL conditions are met simultaneously.</sys:String>
    <sys:String x:Key="ConditionA">Condition A:</sys:String>
    <sys:String x:Key="ConditionB">Condition B:</sys:String>
    <sys:String x:Key="SelectBothConditions">Check both conditions...</sys:String>
    <sys:String x:Key="BothConditionsMet">🎉 Both conditions met!</sys:String>
    <sys:String x:Key="Trigger4">4. EventTrigger — fires on event</sys:String>
    <sys:String x:Key="Trigger4Desc">Starts an animation or action when an event occurs (MouseEnter, MouseLeave, Loaded, etc.).</sys:String>
    <sys:String x:Key="HoverMe">Hover over me!</sys:String>
    <sys:String x:Key="LoadedAnimation">Animation by Loaded event</sys:String>
    <sys:String x:Key="StatusNone">Status: None</sys:String>
    <sys:String x:Key="StatusOk">✔ Status: OK</sys:String>
    <sys:String x:Key="StatusError">✘ Status: Error</sys:String>

    <!-- Items -->
    <sys:String x:Key="Item1">Item 1</sys:String>
    <sys:String x:Key="Item2">Item 2</sys:String>
    <sys:String x:Key="Item3">Item 3</sys:String>

    <!-- MessageBox -->
    <sys:String x:Key="LanguageChangedMessage">Language changed to English</sys:String>
    <sys:String x:Key="LanguageChangedTitle">Language Change</sys:String>
</ResourceDictionary>
