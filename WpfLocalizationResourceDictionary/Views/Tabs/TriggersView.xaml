<UserControl x:Class="WpfLocalizationResourceDictionary.Views.Tabs.TriggersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfLocalizationResourceDictionary.ViewModels">
    <UserControl.DataContext>
        <vm:TriggersViewModel/>
    </UserControl.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{DynamicResource TriggersTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource TriggersDescription}" TextWrapping="Wrap" Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource Trigger1}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource Trigger1Desc}" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource EnableButton}" VerticalAlignment="Center" Width="160"/>
                <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Content="{DynamicResource TriggerButtonText}" IsEnabled="{Binding IsEnabled}" HorizontalAlignment="Left" Padding="12,6" Margin="0,10,0,20">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="LightGreen"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="LightGray"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="DeepSkyBlue"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Separator Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource Trigger2}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource Trigger2Desc}" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="{DynamicResource Ok}" Command="{Binding SetStatusOkCommand}" Padding="12,6" Margin="0,0,10,0"/>
                <Button Content="{DynamicResource Error}" Command="{Binding SetStatusErrorCommand}" Padding="12,6" Margin="0,0,10,0"/>
                <Button Content="{DynamicResource Reset}" Command="{Binding SetStatusNoneCommand}" Padding="12,6"/>
            </StackPanel>
            <Border Width="250" Height="50" CornerRadius="6" HorizontalAlignment="Left" Margin="0,0,0,6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="LightGray"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="Ок">
                                <Setter Property="Background" Value="LightGreen"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Ошибка">
                                <Setter Property="Background" Value="Salmon"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="14">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{DynamicResource StatusNone}"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Status}" Value="Ок">
                                    <Setter Property="Text" Value="{DynamicResource StatusOk}"/>
                                    <Setter Property="Foreground" Value="DarkGreen"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Status}" Value="Ошибка">
                                    <Setter Property="Text" Value="{DynamicResource StatusError}"/>
                                    <Setter Property="Foreground" Value="DarkRed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
            <Separator Margin="0,20,0,20"/>
            <TextBlock Text="{DynamicResource Trigger3}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource Trigger3Desc}" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource ConditionA}" VerticalAlignment="Center" Width="160"/>
                <CheckBox IsChecked="{Binding ConditionA}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{DynamicResource ConditionB}" VerticalAlignment="Center" Width="160"/>
                <CheckBox IsChecked="{Binding ConditionB}" VerticalAlignment="Center"/>
            </StackPanel>
            <Border Width="250" Height="50" CornerRadius="6" HorizontalAlignment="Left" Margin="0,0,0,20">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="LightGray"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ConditionA}" Value="True"/>
                                    <Condition Binding="{Binding ConditionB}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="Gold"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{DynamicResource SelectBothConditions}"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ConditionA}" Value="True"/>
                                        <Condition Binding="{Binding ConditionB}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Text" Value="{DynamicResource BothConditionsMet}"/>
                                    <Setter Property="Foreground" Value="DarkGoldenrod"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
            <Separator Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource Trigger4}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="{DynamicResource Trigger4Desc}" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,10"/>
            <Button Content="{DynamicResource HoverMe}" HorizontalAlignment="Left" Padding="12,6" Margin="0,0,0,10" Width="220">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Background" Value="LightBlue"/>
                    </Style>
                </Button.Style>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="FontSize" To="18" Duration="0:0:0.2"/></Storyboard></BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetProperty="FontSize" To="14" Duration="0:0:0.2"/></Storyboard></BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>
            <Border Width="250" Height="50" CornerRadius="6" HorizontalAlignment="Left" Name="AnimatedBorder" Background="LightBlue">
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard><Storyboard RepeatBehavior="Forever" AutoReverse="True"><ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" From="LightBlue" To="LightCoral" Duration="0:0:1.5"/></Storyboard></BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <TextBlock Text="{DynamicResource LoadedAnimation}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
