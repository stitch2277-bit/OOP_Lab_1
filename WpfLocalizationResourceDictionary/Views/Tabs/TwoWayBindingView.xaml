<UserControl x:Class="WpfLocalizationResourceDictionary.Views.Tabs.TwoWayBindingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfLocalizationResourceDictionary.ViewModels">
    <UserControl.DataContext>
        <vm:TwoWayBindingViewModel/>
    </UserControl.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{DynamicResource TwoWayTitle}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource TwoWayDescription}" TextWrapping="Wrap" Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource ElementBindingTwoWay}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource TextBox1}" VerticalAlignment="Center" Width="120"/>
                <TextBox x:Name="SourceTextBox" Width="200" Padding="4" Text="{DynamicResource SyncText}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource TextBox2}" VerticalAlignment="Center" Width="120"/>
                <TextBox Width="200" Padding="4" Text="{Binding ElementName=SourceTextBox, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource Slider}" VerticalAlignment="Center" Width="120"/>
                <Slider x:Name="DirectSlider" Width="150" Minimum="0" Maximum="100" Value="50"/>
                <TextBox Width="60" Margin="10,0,0,0" Padding="4" Text="{Binding ElementName=DirectSlider, Path=Value, Mode=TwoWay, StringFormat={}{0:F0}}"/>
            </StackPanel>
            <Separator Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource ViewModelBindingTwoWay}" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource TextBox1}" VerticalAlignment="Center" Width="120"/>
                <TextBox Width="200" Padding="4" Text="{Binding TextValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource Display}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding TextValue}" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource Slider}" VerticalAlignment="Center" Width="120"/>
                <Slider Value="{Binding SliderValue, Mode=TwoWay}" Width="150" Minimum="0" Maximum="100"/>
                <TextBox Width="60" Margin="10,0,0,0" Padding="4" Text="{Binding SliderValue, Mode=TwoWay, StringFormat={}{0:F0}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource Progress}" VerticalAlignment="Center" Width="120"/>
                <ProgressBar Value="{Binding SliderValue, Mode=TwoWay}" Width="200" Height="20" Minimum="0" Maximum="100"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource CheckBox}" VerticalAlignment="Center" Width="120"/>
                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Content="{DynamicResource Enable}" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource State}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding IsChecked}" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="{DynamicResource ComboBox}" VerticalAlignment="Center" Width="120"/>
                <ComboBox SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}" Width="200">
                    <ComboBoxItem Content="{DynamicResource OptionA}"/>
                    <ComboBoxItem Content="{DynamicResource OptionB}"/>
                    <ComboBoxItem Content="{DynamicResource OptionC}"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <TextBlock Text="{DynamicResource SelectedIndex}" VerticalAlignment="Center" Width="120"/>
                <TextBlock Text="{Binding SelectedIndex}" VerticalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
            <Button Content="{DynamicResource ResetAll}" Command="{Binding ResetCommand}" HorizontalAlignment="Left" Padding="12,6"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
